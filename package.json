{
  "name": "llm-calc",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check:skill-sync": "node ../.claude/hooks/check-skill-sync.mjs",
    "cli": "tsx src/cli.ts",
    "deploy": "vite build && wrangler deploy",
    "deploy:dry": "vite build && wrangler deploy --dry-run"
  },
  "bin": {
    "llm-calc": "./bin/llm-calc.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^25.7.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.90.0"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17"
  }
}
